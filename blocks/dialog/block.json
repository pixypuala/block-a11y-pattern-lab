{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "pixy-a11y/dialog",
  "version": "0.1.0",
  "title": "Accessible Dialog",
  "category": "design",
  "description": "A WAI-ARIA modal dialog with a focus trap, Escape to dismiss, and focus restoration to the opener.",
  "keywords": ["accessibility", "a11y", "aria", "dialog", "modal"],
  "textdomain": "block-a11y-pattern-lab",
  "attributes": {
    "triggerLabel": { "type": "string", "default": "Open dialog" },
    "title": { "type": "string", "default": "Confirm action" },
    "body": { "type": "string", "default": "Dialog body content." },
    "closeLabel": { "type": "string", "default": "Close" }
  },
  "editorScript": "file:./index.js",
  "viewScript": "file:./view.js",
  "supports": {
    "html": false
  }
}
